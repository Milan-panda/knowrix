# ─── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=dev                       # dev | prod

# ─── Ports ─────────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_EXPOSED_PORT=5432            # Only used in dev (exposed to host)
QDRANT_EXPOSED_PORT=6333              # Only used in dev

# ─── URLs (used by frontend and for CORS validation) ───────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000     # Prod: https://api.contextiq.dev
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000    # Prod: https://app.contextiq.dev

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000    # Prod: https://app.contextiq.dev,https://contextiq.dev

# ─── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres                # Docker service name — unchanged dev/prod
POSTGRES_PORT=5432
POSTGRES_DB=contextiq
POSTGRES_USER=contextiq
POSTGRES_PASSWORD=changeme

# ─── Qdrant ─────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ─── MinIO ──────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=http://minio:9000      # Internal Docker network URL
MINIO_BUCKET=contextiq

# ─── OpenRouter (LLM) ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key              # Get from https://openrouter.ai/keys
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=stepfun/step-3.5-flash:free

# ─── Embedding ──────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ─── Auth (NextAuth) ────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── GitHub OAuth (workspace connectors: private repos + discussions) ────────────
# Create OAuth App: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: {BACKEND_URL}/api/v1/workspaces/connectors/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# Optional: fallback token when no workspace has connected GitHub (public-only use)
GITHUB_TOKEN=your-github-token

# ─── Notion OAuth (workspace connectors: private pages) ───────────────────────────
# Create public integration: https://www.notion.so/my-integrations → New integration → Public
# Redirect URI in Notion: {BACKEND_URL}/api/v1/workspaces/connectors/notion/callback
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
# Optional: override redirect (default: BACKEND_URL + /api/v1/workspaces/connectors/notion/callback)
# NOTION_REDIRECT_URI=
# Optional: fallback when no workspace has connected Notion (internal integration token)
NOTION_API_KEY=

# ─── Connector token encryption (recommended in production) ──────────────────────
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Or use any long random secret; it will be derived with PBKDF2 if not 44-char base64
ENCRYPTION_KEY=your-encryption-key

# ─── SSL / Certbot (prod only) ────────────────────────────────────────────────
API_DOMAIN=your-api-domain
CERT_EMAIL=your-email@example.com            # Let's Encrypt registration email

# ─── Telegram Bot (optional) ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Optional
IPINFO_TOKEN=ipinfo-token